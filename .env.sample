# Google Sheet 的 spreadsheet ID
# 例如 https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEET_ID=your_google_sheet_id

# 工作表名稱可選填。
# 如果不填，程式會依站台自動分流：
# - cake -> cake_jobs
# - 104 -> 104_jobs
# GOOGLE_SHEET_NAME=custom_jobs

# Google service account JSON 檔案路徑
GOOGLE_SERVICE_ACCOUNT_JSON=secrets/google-service-account.json

# SMTP 伺服器位址，Gmail 通常是 smtp.gmail.com
SMTP_HOST=smtp.gmail.com

# SMTP port，Gmail STARTTLS 通常是 587
SMTP_PORT=587

# SMTP 登入帳號，通常就是寄件信箱
SMTP_USERNAME=your-email@gmail.com

# SMTP 密碼；如果是 Gmail，通常要填 app password，不是一般登入密碼
SMTP_PASSWORD=your-app-password

# 寄件者 email
SMTP_FROM_EMAIL=your-email@gmail.com

# 人類可讀摘要信的收件者
SMTP_TO_EMAIL=recipient@example.com

# 是否另外寄一封 machine-readable JSON email
MACHINE_EMAIL_ENABLED=false

# JSON 通知信的收件者
MACHINE_EMAIL_TO=machine-consumer@example.com
